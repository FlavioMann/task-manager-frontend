    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.27",
    "happy-dom": "^20.8.9",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.42.0",
